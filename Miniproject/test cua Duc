# Yêu cầu người dùng nhập vào Số lượng tồn kho
so_luong = int(input("Nhập số lượng tồn kho của mặt hàng: "))

if so_luong >= 50:
    print("Tình trạng: Hàng đầy kho")
elif 10 <= so_luong < 50:
    print("Tình trạng: Mức an toàn")
else:
    print("Tình trạng: Sắp hết hàng, cần báo cáo nhập thêm")

# khai báo biến để lưu trữ tổng số hàng lỗi ( ban đầu bằng 0)
tong_so_hang_loi = 0
# sử dụng vòng lặp while True
while True:
    so_luong= int(input("Nhập số lượng hàng lỗi của quầy (nhập -1 để kết thúc): "))
    if so_luong == -1:
        break
# Nếu người dùng nhập số khác -1: Cộng dồn vào tổng số hàng lỗi
    if so_luong > 0:
    tong_so_hang_loi += so_luong
    else:
      print("Vui lòng nhập số dương hoặc -1 để thoát.")
            
    except ValueError:
      print("Vui lòng nhập một số nguyên hợp lệ.")
print(f"Tổng số hàng lỗi thu hồi trong ngày là: {tong_so_hang_loi}")

